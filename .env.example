# MongoDB (set automatically by docker-compose — override for external cluster)
MONGO_URL=mongodb://db:27017
DB_NAME=munkerhex

# Supabase — create a project at https://supabase.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJh...
SUPABASE_SERVICE_KEY=eyJh...
SUPABASE_JWT_SECRET=your-jwt-secret

# Stripe — find these at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create products at https://dashboard.stripe.com/products
STRIPE_PRICE_DESIGNER=price_...
STRIPE_PRICE_STUDIO=price_...
STRIPE_PRICE_AGENCY=price_...

# Public URL of this server (used in Stripe checkout redirect)
PUBLIC_URL=https://yourdomain.com
